# Apify API Token
# Get it from: https://console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_token_here

# Anthropic Claude API Key
# Get it from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_claude_api_key_here

# ── Password gate (interná aplikácia) ─────────────────────────────
# APP_PASSWORD: jediné univerzálne heslo, ktoré zadá kolega pri vstupe.
APP_PASSWORD=zmen-toto-heslo

# AUTH_SECRET: náhodný reťazec na podpisovanie auth cookie.
# Vygeneruj napr.:  openssl rand -hex 32
# (ak ho nenastavíš, použije sa APP_PASSWORD — ale v produkcii nastav vlastný)
AUTH_SECRET=vygeneruj-nahodny-secret-cez-openssl-rand-hex-32

# App Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
